%%% Escape sequences

        \# \$ \@ \~ \* \| \\ \( \) \[ \] \{ \}
%%      ^^ ^^ ^^ ^^ ^^ ^^ ^^ ^^ ^^ ^^ ^^ ^^ ^^ nil
        \\# \\$ \\@ \\~ \\* \\| \\\ \\( \\) \\[ \\] \\{ \\} \
